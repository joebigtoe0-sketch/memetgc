generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id           String   @id
  name         String
  set          String
  type         String
  faction      String
  rarity       String
  tribe        String?
  cost         Int
  attack       Int?
  health       Int?
  durability   Int?
  armor        Int?
  text         String?
  flavorText   String?  @map("flavor_text")
  artLabel     String?  @map("art_label")
  keywordsJson Json     @default("[]") @map("keywords_json")
  effectsJson  Json     @default("[]") @map("effects_json")
  heroPowerJson Json?   @map("hero_power_json")
  artUrl       String?  @map("art_url")
  cardBack     String?  @map("card_back")
  isAnimated   Boolean  @default(false) @map("is_animated")
  nftTokenId   String?  @map("nft_token_id")
  collectible  Boolean  @default(true)
  craftable    Boolean  @default(true)
  dustValue    Int      @default(0) @map("dust_value")
  craftCost    Int      @default(0) @map("craft_cost")
  createdAt    DateTime @default(now()) @map("created_at")

  deckCards    DeckCard[]
  collections  CollectionEntry[]

  @@map("cards")
}

model Hero {
  id            String   @id
  name          String
  faction       String
  hp            Int      @default(30)
  armor         Int      @default(0)
  heroPowerJson Json     @map("hero_power_json")
  artUrl        String?  @map("art_url")
  unlockMethod  String   @default("default") @map("unlock_method")
  collectible   Boolean  @default(true)
  description   String
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("heroes")
}

model User {
  id                    String    @id @default(cuid())
  username              String    @unique
  hasUsername           Boolean   @default(false) @map("has_username")
  authNonce             String?   @map("auth_nonce")
  email                 String?   @unique
  passwordHash          String?   @map("password_hash")
  walletAddress         String?   @unique @map("wallet_address")
  accessTier            String    @default("casual") @map("access_tier")
  fragments             Int       @default(0)
  packsOpened           Int       @default(0) @map("packs_opened")
  rankTier              String    @default("bronze") @map("rank_tier")
  rankStars             Int       @default(0) @map("rank_stars")
  rankPoints            Int       @default(0) @map("rank_points")
  mmr                   Int       @default(1000) @map("mmr")
  seasonPeakPoints      Int       @default(0) @map("season_peak_points")
  seasonWins            Int       @default(0) @map("season_wins")
  seasonLosses          Int       @default(0) @map("season_losses")
  boardThemeId          String    @default("memepool") @map("board_theme_id")
  equippedCardBack      String?   @map("equipped_card_back")
  equippedBadge         String?   @map("equipped_badge")
  standardPacksEpic     Int       @default(0) @map("standard_packs_since_epic")
  standardPacksLegendary Int      @default(0) @map("standard_packs_since_legendary")
  factionPacksEpic      Int       @default(0) @map("faction_packs_since_epic")
  factionPacksLegendary Int       @default(0) @map("faction_packs_since_legendary")
  dailyQuestsRefresh    DateTime? @map("daily_quests_last_refresh")
  firstWinToday         Boolean   @default(false) @map("first_win_today")
  isNewPlayer           Boolean   @default(true) @map("is_new_player")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  collection    CollectionEntry[]
  decks         Deck[]
  matchesAsP1   Match[]           @relation("Player1")
  matchesAsP2   Match[]           @relation("Player2")
  quests        DailyQuest[]
  packs         PackInventory[]
  cosmetics     UserCosmetic[]

  @@map("users")
}

model Season {
  id        String    @id @default(cuid())
  number    Int       @unique
  name      String
  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")
  isActive  Boolean   @default(true) @map("is_active")

  @@map("seasons")
}

model UserCosmetic {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String // "card_back" | "badge"
  value     String
  seasonId  String?  @map("season_id")
  grantedAt DateTime @default(now()) @map("granted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, value])
  @@index([userId])
  @@map("user_cosmetics")
}

model PackInventory {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  packType String @map("pack_type")
  quantity Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, packType])
  @@map("pack_inventory")
}

model CollectionEntry {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  cardId   String @map("card_id")
  quantity Int    @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@map("collection_entries")
}

model Deck {
  id                String     @id @default(cuid())
  userId            String     @map("user_id")
  name              String
  heroId            String     @map("hero_id")
  faction           String?
  factionBonusActive Boolean   @default(false) @map("faction_bonus_active")
  isStarter         Boolean    @default(false) @map("is_starter")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  deckCards DeckCard[]

  @@map("decks")
}

model DeckCard {
  id       String @id @default(cuid())
  deckId   String @map("deck_id")
  cardId   String @map("card_id")
  quantity Int    @default(1)

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([deckId, cardId])
  @@map("deck_cards")
}

model Match {
  id          String    @id @default(cuid())
  player1Id   String    @map("player1_id")
  player2Id   String?   @map("player2_id")
  mode        String
  winnerId    String?   @map("winner_id")
  endReason   String?   @map("end_reason")
  turnCount   Int?      @map("turn_count")
  seasonId    String?   @map("season_id")
  startedAt   DateTime  @default(now()) @map("started_at")
  endedAt     DateTime? @map("ended_at")
  gameStateJson Json?   @map("game_state_json")

  player1 User  @relation("Player1", fields: [player1Id], references: [id])
  player2 User? @relation("Player2", fields: [player2Id], references: [id])

  @@map("matches")
}

model MarketListing {
  id            String    @id @default(cuid())
  sellerId      String    @map("seller_id")
  kind          String // "card" | "pack"
  cardId        String?   @map("card_id")
  packType      String?   @map("pack_type")
  price         Decimal   @db.Decimal(20, 6)
  status        String    @default("active") // active | reserved | cancelling | sold | cancelled
  reservedById  String?   @map("reserved_by_id")
  reservedUntil DateTime? @map("reserved_until")
  cooldownUntil DateTime? @map("cooldown_until")
  buyerId       String?   @map("buyer_id")
  txSignature   String?   @unique @map("tx_signature")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  soldAt        DateTime? @map("sold_at")
  cancelledAt   DateTime? @map("cancelled_at")

  @@index([kind, cardId, status])
  @@index([kind, packType, status])
  @@index([sellerId])
  @@index([reservedById])
  @@map("market_listings")
}

model DailyQuest {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  type        String
  description String
  progress    Int       @default(0)
  target      Int
  rewardJson  Json      @map("reward_json")
  completed   Boolean   @default(false)
  claimedAt   DateTime? @map("claimed_at")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("daily_quests")
}
