PORT=3001
DATABASE_URL="postgresql://postgres:password@localhost:5432/memetgc"
JWT_SECRET="your-super-secret-jwt-key-change-this"
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:3000

# --- Solana / $MEMEPOOL balance (Helius) ---
# Your Helius API key (https://helius.dev)
HELIUS_API_KEY=""
# The $MEMEPOOL SPL token mint address on Solana (DEGEN_MINT env var name kept for compatibility)
DEGEN_MINT=""
# Optional override for the Helius RPC base (defaults to mainnet)
HELIUS_RPC_URL="https://mainnet.helius-rpc.com"

# --- Marketplace / token gate ---
# Treasury wallet that collects the 5% marketplace fee (Solana address)
TREASURY_WALLET=""
# Minimum $MEMEPOOL a wallet must hold to play (default 1000)
MIN_PLAY_TOKENS="1000"
