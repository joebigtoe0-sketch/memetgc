{
  "name": "@memetgc/card-art",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "tsx src/generate.ts --source=seed",
    "generate:dry": "tsx src/generate.ts --source=seed --dry-run --limit=3",
    "generate:genesis-drop": "tsx src/generate.ts --source=seed --set=genesis_drop --limit=30",
    "generate:genesis-drop:dry": "tsx src/generate.ts --source=seed --set=genesis_drop --dry-run --limit=30",
    "generate:expansion": "tsx src/generate.ts --source=seed --expansion --limit=40",
    "generate:expansion:dry": "tsx src/generate.ts --source=seed --expansion --dry-run --limit=40",
    "generate:db": "tsx src/generate.ts --source=db",
    "generate:db:genesis-drop": "tsx src/generate.ts --source=db --set=genesis_drop --limit=30",
    "generate:db:expansion": "tsx src/generate.ts --source=db --expansion --limit=40",
    "regenerate:humans": "tsx src/generate.ts --source=seed --force-humans",
    "sync:db": "tsx src/syncToDb.ts",
    "sync:manifest": "tsx src/syncManifest.ts"
  },
  "dependencies": {
    "@memetgc/db": "workspace:*",
    "dotenv": "^16.5.0",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
