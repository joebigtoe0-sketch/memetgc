# OpenAI — get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Image generation — try gpt-image-2 first; script falls back automatically
IMAGE_MODEL=gpt-image-2
IMAGE_SIZE=1024x1536
IMAGE_QUALITY=high
IMAGE_DELAY_MS=1500

# LLM used only when a card has no hand-written art brief in art-labels.ts
BRIEF_MODEL=gpt-4.1

# Where PNGs are saved (served at /card-art/{id}.png)
IMAGE_OUTPUT_DIR=../../apps/web/public/card-art

# Prompt logs for debugging / re-rolls
IMAGE_LOG_DIR=./logs

# Database — copy DATABASE_URL from packages/db/.env
DATABASE_URL=
